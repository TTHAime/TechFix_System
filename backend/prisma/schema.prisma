// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider      = "prisma-client"
  output        = "../src/generated/prisma"
  moduleFormat  = "cjs"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique @db.VarChar(50)

  users User[]

  @@map("roles")
}

model Department {
  id       Int    @id @default(autoincrement())
  name     String @unique @db.VarChar(100)
  location String @db.VarChar(100)

  users     User[]
  equipment Equipment[]

  @@map("departments")
}

model User {
  id             Int       @id @default(autoincrement())
  name           String    @db.VarChar(100)
  email          String    @unique @db.VarChar(100)
  roleId         Int       @map("role_id")
  deptId         Int       @map("dept_id")
  provider       String    @db.VarChar(20)   // 'google' | 'local'
  providerUid    String?   @map("provider_uid") @db.VarChar(100)
  passwordHash   String?   @map("password_hash")
  failedAttempts Int       @default(0) @map("failed_attempts")
  lockedUntil    DateTime? @map("locked_until") @db.Timestamptz
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz

  role       Role       @relation(fields: [roleId], references: [id])
  department Department @relation(fields: [deptId], references: [id])

  refreshTokens        RefreshToken[]
  repairRequests       RepairRequest[]     @relation("RequesterRequests")
  statusLogsChanged    StatusLog[]         @relation("StatusChangedBy")
  assignmentLogsActor  AssignmentLog[]     @relation("AssignmentActor")
  assignmentLogsTech   AssignmentLog[]     @relation("AssignmentTechnician")
  assignedItems        RequestEquipment[]  @relation("ItemTechnician")
  auditLogs            AuditLog[]

  @@index([roleId])
  @@index([deptId])
  @@map("users")
}

model RefreshToken {
  id          Int       @id @default(autoincrement())
  userId      Int       @map("user_id")
  tokenHash   String    @map("token_hash")
  expiresAt   DateTime  @map("expires_at") @db.Timestamptz
  revokedAt   DateTime? @map("revoked_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("refresh_tokens")
}

model EquipmentCategory {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(100)

  equipment        Equipment[]
 
  @@map("equipment_categories")
}

model Equipment {
  id         Int     @id @default(autoincrement())
  name       String  @db.VarChar(100)
  serialNo   String  @unique @db.VarChar(100) @map("serial_no")
  categoryId Int     @map("category_id")
  deptId     Int     @map("dept_id")
  isActive   Boolean @default(true) @map("is_active")

  category         EquipmentCategory  @relation(fields: [categoryId], references: [id])
  department       Department         @relation(fields: [deptId], references: [id])
  requestEquipment RequestEquipment[]

  @@index([categoryId])
  @@index([deptId])
  @@map("equipment")
}

model RequestStatus {
  id   Int    @id @default(autoincrement())
  name String @db.VarChar(50)  // 'open' | 'in_progress' | 'resolved' | 'closed'

  repairRequests   RepairRequest[]
  statusLogsOld    StatusLog[]        @relation("OldStatus")
  statusLogsNew    StatusLog[]        @relation("NewStatus")
  requestEquipment RequestEquipment[] @relation("ItemStatus")

  @@map("request_status")
}

model RepairRequest {
  id            Int       @id @default(autoincrement())
  requesterId   Int       @map("requester_id")
  statusId      Int       @map("status_id")
  description   String
  completedAt   DateTime? @map("completed_at") @db.Timestamptz
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  requester        User               @relation("RequesterRequests", fields: [requesterId], references: [id])
  status           RequestStatus      @relation(fields: [statusId], references: [id])
  requestEquipment RequestEquipment[]
  statusLogs       StatusLog[]
  assignmentLogs   AssignmentLog[]

  @@index([requesterId])
  @@index([statusId])
  @@map("repair_requests")
}

model RequestEquipment {
  requestId     Int       @map("request_id")
  seqNo         Int       @map("seq_no")               // sequential per request (1, 2, 3…)
  equipmentId   Int       @map("equipment_id")
  issueDetail   String    @map("issue_detail")
  statusId      Int       @default(1) @map("status_id")  // FK -> RequestStatus (default: open)
  technicianId  Int?      @map("technician_id")           // technician who accepted this item
  partsUsed     String?   @map("parts_used")
  repairSummary String?   @map("repair_summary")
  resolvedAt    DateTime? @map("resolved_at") @db.Timestamptz

  request    RepairRequest @relation(fields: [requestId], references: [id])
  equipment  Equipment     @relation(fields: [equipmentId], references: [id])
  status     RequestStatus @relation("ItemStatus", fields: [statusId], references: [id])
  technician User?         @relation("ItemTechnician", fields: [technicianId], references: [id])

  assignmentLogs AssignmentLog[]

  @@id([requestId, seqNo])
  @@index([equipmentId])
  @@index([statusId])
  @@index([technicianId])
  @@map("request_equipment")
}

model StatusLog {
  id          Int      @id @default(autoincrement())
  requestId   Int      @map("request_id")
  changedBy   Int      @map("changed_by")
  oldStatusId Int      @map("old_status")
  newStatusId Int      @map("new_status")
  note        String?
  changedAt   DateTime @default(now()) @map("changed_at") @db.Timestamptz

  request   RepairRequest @relation(fields: [requestId], references: [id])
  changer   User          @relation("StatusChangedBy", fields: [changedBy], references: [id])
  oldStatus RequestStatus @relation("OldStatus", fields: [oldStatusId], references: [id])
  newStatus RequestStatus @relation("NewStatus", fields: [newStatusId], references: [id])

  @@index([requestId])
  @@map("status_logs")
}

model AssignmentLog {
  id              Int      @id @default(autoincrement())
  requestId       Int      @map("request_id")
  itemRequestId   Int?     @map("item_request_id")   // FK part 1 -> RequestEquipment (null = request-level)
  itemSeqNo       Int?     @map("item_seq_no")        // FK part 2 -> RequestEquipment
  actorId         Int      @map("actor_id")
  technicianId    Int      @map("technician_id")
  action          String   @db.VarChar(20)            // 'assigned' | 'unassigned'
  loggedAt        DateTime @default(now()) @map("logged_at") @db.Timestamptz

  request    RepairRequest     @relation(fields: [requestId], references: [id])
  item       RequestEquipment? @relation(fields: [itemRequestId, itemSeqNo], references: [requestId, seqNo])
  actor      User              @relation("AssignmentActor", fields: [actorId], references: [id])
  technician User              @relation("AssignmentTechnician", fields: [technicianId], references: [id])

  @@index([requestId])
  @@index([itemRequestId, itemSeqNo])
  @@map("assignment_logs")
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  actorId    Int      @map("actor_id")
  entityType String   @db.VarChar(50)  // 'user' | 'equipment' | 'department'
  entityId   Int      @map("entity_id")
  action     String   @db.VarChar(20)  // 'created' | 'updated' | 'deleted'
  oldValue   Json?    @map("old_value")
  newValue   Json?    @map("new_value")
  loggedAt   DateTime @default(now()) @map("logged_at") @db.Timestamptz

  actor User @relation(fields: [actorId], references: [id])

  @@index([actorId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}