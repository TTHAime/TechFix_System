meta {
  name: XSS script in query
  type: http
  seq: 22
}

get {
  url: {{base_url}}/users?search=<img src=x onerror=alert(1)
  body: none
  auth: bearer
}

params:query {
  search: <img src=x onerror=alert(1)
}

auth:bearer {
  token: {{hr_token}}
}

tests {
  test("status 200", function() {
    expect(res.status).to.equal(200);
  });
  
  test("returns data array", function() {
    expect(res.body.data).to.be.an("array");
  });
}
