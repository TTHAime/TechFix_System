meta {
  name: Login Admin test
  type: http
  seq: 12
}

post {
  url: {{base_url}}/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "{{admin_email}}",
    "password": "123456"
  }
}

script:post-response {
  if (res.status === 200) {
    bru.setEnvVar("admin_token", res.body.accessToken);
    bru.setEnvVar("access_token", res.body.accessToken);
  }
}
