meta {
  name: Login Admin
  type: http
  seq: 1
}

post {
  url: {{base_url}}/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "{{admin_email}}",
    "password": "{{admin_password}}"
  }
}

script:post-response {
  if (res.status === 200) {
    bru.setEnvVar("admin_token", res.body.accessToken);
    bru.setEnvVar("access_token", res.body.accessToken);
  }
}
